{
  "name": "buildmybot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx server/index.ts",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "lint": "biome check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/seeds/seedTemplates.ts",
    "seed:roles": "tsx server/seeds/seedUserRoles.ts",
    "seed:revenue": "tsx server/seeds/revenue-seed.ts",
    "seed:kb": "tsx server/seeds/industryKnowledgeBases.ts",
    "seed:all": "npm run db:seed && npm run seed:roles && npm run seed:revenue && npm run seed:kb",
    "migrate:schema": "tsx scripts/runMigrations.ts",
    "migrate:data": "tsx scripts/runDataMigration.ts",
    "migrate:all": "npm run migrate:schema && npm run migrate:data",
    "set-admin-permissions": "tsx scripts/setAdminPermissions.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/express-session": "^1.18.2",
    "@types/memoizee": "^0.4.12",
    "@types/multer": "^2.0.0",
    "@types/p-limit": "^2.1.0",
    "@types/p-retry": "^3.0.0",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.14",
    "autoprefixer": "^10.4.23",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.4.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.11.0",
    "memoizee": "^0.4.17",
    "multer": "^2.0.2",
    "openai": "^6.16.0",
    "openid-client": "^6.8.1",
    "p-limit": "^7.2.0",
    "p-retry": "^7.1.1",
    "passport": "^0.7.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "postgres": "^3.4.8",
    "railway": "^2.0.17",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.2",
    "stripe": "^20.1.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.3",
    "uuid": "^11.1.0",
    "zod": "^4.3.5",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.27",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.0.4",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "jsdom": "^23.0.1",
    "typescript": "^5.4.2",
    "vite": "^5.1.5",
    "vitest": "^1.0.4"
  }
}
