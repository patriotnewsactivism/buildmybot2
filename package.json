{
  "name": "buildmybot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite",
    "server": "tsx server/index.ts",
    "build": "tsc && vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "lint": "biome check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:status": "tsx scripts/migrate.ts --status",
    "db:migrate:up": "tsx scripts/migrate.ts",
    "db:migrate:down": "tsx scripts/migrate.ts --down",
    "db:seed": "tsx scripts/seed.ts",
    "db:seed:status": "tsx scripts/seed.ts --status",
    "db:seed:force": "tsx scripts/seed.ts --force",
    "db:seed:only": "tsx scripts/seed.ts --only",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "db:reset": "echo 'WARNING: This will reset your database!' && npm run db:migrate:down -- --steps=10 && npm run db:migrate && npm run db:seed",
    "migrate:schema": "echo 'DEPRECATED: Use db:migrate instead' && tsx scripts/runMigrations.ts",
    "migrate:data": "echo 'DEPRECATED: Use db:migrate instead' && tsx scripts/runDataMigration.ts",
    "migrate:all": "echo 'DEPRECATED: Use db:setup instead' && npm run migrate:schema && npm run migrate:data",
    "seed:roles": "echo 'DEPRECATED: Use db:seed --only=user-roles instead' && tsx server/seeds/seedUserRoles.ts",
    "seed:revenue": "echo 'DEPRECATED: Use db:seed --only=revenue-tables instead' && tsx server/seeds/revenue-seed.ts",
    "seed:kb": "echo 'DEPRECATED: Use db:seed --only=industry-knowledge instead' && tsx server/seeds/industryKnowledgeBases.ts",
    "seed:all": "echo 'DEPRECATED: Use db:seed instead' && npm run db:seed && npm run seed:roles && npm run seed:revenue && npm run seed:kb",
    "set-admin-permissions": "echo 'DEPRECATED: Admin permissions are now set via db:seed --only=user-roles' && tsx scripts/setAdminPermissions.ts"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@sentry/node": "^10.32.1",
    "@sentry/profiling-node": "^10.32.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/express-session": "^1.18.2",
    "@types/memoizee": "^0.4.12",
    "@types/multer": "^2.0.0",
    "@types/p-limit": "^2.1.0",
    "@types/p-retry": "^3.0.0",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.16.0",
    "@types/uuid": "^10.0.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.14",
    "autoprefixer": "^10.4.23",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.4.1",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "framer-motion": "^12.26.2",
    "helmet": "^8.1.0",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "jsdom": "^23.2.0",
    "lovable": "^0.0.0",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.11.0",
    "memoizee": "^0.4.17",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.12",
    "openai": "^6.16.0",
    "openid-client": "^6.8.1",
    "p-limit": "^7.2.0",
    "p-retry": "^7.1.1",
    "passport": "^0.7.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "postgres": "^3.4.8",
    "railway": "^2.0.17",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.2",
    "recharts": "^2.12.2",
    "retell-sdk": "^5.17.0",
    "stripe": "^20.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.20.3",
    "twilio": "^5.11.2",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "ws": "^8.19.0",
    "zod": "^4.3.5",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.30",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/twilio": "^3.19.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.0.4",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "md-to-pdf": "^5.2.5",
    "typescript": "^5.4.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  }
}
