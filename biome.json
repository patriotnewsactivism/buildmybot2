{
  "$schema": "https://biomejs.dev/schemas/1.8.3/schema.json",
  "files": {
    "ignore": [
      "dist",
      "node_modules",
      "uploads",
      "**/*.css",
      "scripts/**",
      ".vercel/**",
      ".local/**",
      ".claude/**",
      "coverage/**"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "warn",
        "noConsole": "off",
        "noImplicitAnyLet": "warn"
      },
      "a11y": {
        "noLabelWithoutControl": "warn",
        "useKeyWithClickEvents": "warn",
        "useValidAnchor": "warn",
        "noSvgWithoutTitle": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noEmptyPattern": "warn"
      },
      "complexity": {
        "noForEach": "warn",
        "noStaticOnlyClass": "warn"
      },
      "style": {
        "noCommaOperator": "warn",
        "noNonNullAssertion": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  }
}
