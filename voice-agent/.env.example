PORT=3000

# STT Configuration
# Options: 'deepgram'
STT_PROVIDER=deepgram

# LLM Configuration
# Options: 'openai'
LLM_PROVIDER=openai

# TTS Configuration
# Options: 'cartesia', 'elevenlabs'
TTS_PROVIDER=cartesia

# Shadow Mode Configuration
# Set this to a provider name to run it in parallel (shadow mode)
# Leave empty to disable shadow mode.
# SHADOW_TTS_PROVIDER=elevenlabs

# API Keys
CARTESIA_API_KEY=your_cartesia_key
ELEVENLABS_API_KEY=your_elevenlabs_key
OPENAI_API_KEY=your_openai_key
DEEPGRAM_API_KEY=your_deepgram_key
