# BuildMyBot Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
SESSION_SECRET=change-me-to-a-random-string

# Database (Railway provides this automatically)
# DATABASE_URL=postgresql://user:pass@host:port/db

# OpenAI
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WHITELABEL_PRICE_ID=price_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase (optional, for auth/storage)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Voice - Retell AI (recommended)
RETELL_API_KEY=key_...
RETELL_DEFAULT_VOICE_ID=11labs-Adrian

# Voice - Cartesia TTS
CARTESIA_API_KEY=sk_car_...
TTS_PROVIDER=cartesia
SHADOW_TTS_PROVIDER=

# Voice - Twilio (for phone numbers)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Frontend
VITE_API_URL=http://localhost:3000
VITE_ENVIRONMENT=development

# Analytics (optional)
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=

# Error tracking (optional)
VITE_SENTRY_DSN=
VITE_SENTRY_ORG=
VITE_SENTRY_PROJECT=
VITE_SENTRY_AUTH_TOKEN=

# Launch Gate (set to false when ready to accept purchases)
LAUNCH_GATE_ENABLED=true
